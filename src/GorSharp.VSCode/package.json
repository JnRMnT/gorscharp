{
  "name": "gorsharp",
  "displayName": "Gör# — Turkish C# Transpiler",
  "description": "Language support for Gör# (.gör) — a Turkish-to-C# educational transpiler",
  "version": "0.1.0",
  "publisher": "gorsharp",
  "license": "MIT",
  "icon": "icons/gorsharp-extension.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/gorsharp/gorsharp.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Education"
  ],
  "keywords": [
    "turkish",
    "csharp",
    "transpiler",
    "educational",
    "gorsharp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gorsharp",
        "aliases": [
          "Gör#",
          "GorSharp",
          "gorsharp"
        ],
        "extensions": [
          ".gör"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/gorsharp-light.png",
          "dark": "./icons/gorsharp-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "gorsharp",
        "scopeName": "source.gorsharp",
        "path": "./syntaxes/gorsharp.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "gorsharp.transpile",
        "title": "Gör#: Dönüştür (Transpile)",
        "icon": "$(code)"
      },
      {
        "command": "gorsharp.run",
        "title": "Gör#: Çalıştır (Run)",
        "icon": "$(play)"
      },
      {
        "command": "gorsharp.showMirror",
        "title": "Gör#: Ayna Paneli (Mirror Panel)",
        "icon": "$(split-horizontal)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "gorsharp.run",
          "when": "resourceLangId == gorsharp",
          "group": "navigation"
        },
        {
          "command": "gorsharp.showMirror",
          "when": "resourceLangId == gorsharp",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Gör#",
      "properties": {
        "gorsharp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Dil sunucusu (gorsharp-lsp) yolu. Boş bırakılırsa, uzantıyla birlikte gelen sunucu kullanılır."
        },
        "gorsharp.sozlukPath": {
          "type": "string",
          "default": "",
          "description": "sozluk.json dosyasının yolu. Boş bırakılırsa, çalışma alanında otomatik aranır."
        },
        "gorsharp.autoTranspileOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Kaydederken otomatik olarak .cs dosyasına dönüştür."
        },
        "gorsharp.parsingMode": {
          "type": "string",
          "enum": [
            "natural",
            "strict"
          ],
          "default": "natural",
          "description": "Dil çözümleme profili. natural: doğal dil parçacıkları açık, strict: sadece çekirdek sözdizimi."
        }
      }
    },
    "snippets": [
      {
        "language": "gorsharp",
        "path": "./snippets/gorsharp.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "prepackage": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0"
  }
}
