            {
              "name": "constant.character.escape.gorsharp",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.gorsharp",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.gorsharp",
          "match": "\\b\\d+\\b"
        }
